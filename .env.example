# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Orchestration framework ---
# Chosen: LangGraph (see docs/DESIGN_DECISIONS.md). No separate API key
# needed - it just uses whichever LLM provider you configure below.
ORCHESTRATION_FRAMEWORK=langgraph

# --- LLM provider (pick one; framework freedom is yours) ---
LLM_PROVIDER=openai            # openai | anthropic | gemini | groq | ollama
LLM_API_KEY=
LLM_MODEL=gpt-4o                 # e.g. gpt-4o-mini, claude-sonnet-4-6, gemini-1.5-pro

# --- Vector store backend ---
# Chosen: Qdrant (see docs/DESIGN_DECISIONS.md) - for native sparse+dense
# hybrid search.
VECTOR_STORE_BACKEND=qdrant
# Local dev: run `docker run -p 6333:6333 qdrant/qdrant` and leave this as
# the default - no API key needed. For Qdrant Cloud, set this to your
# cluster URL and fill in QDRANT_API_KEY.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=smartdesk_kb
# Alternative to running a server at all: qdrant-client supports an
# embedded "local mode" (QdrantClient(path="./data/processed/qdrant_local"))
# with no Docker/server required - handy if you'd rather skip that step.
VECTOR_INDEX_DIR=./data/processed/vector_index

# --- Embeddings ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=
# For the sparse half of hybrid search you'll also need a sparse model -
# e.g. fastembed's bundled BM25/SPLADE++/miniCOIL sparse models.
# TODO: pick one and record it in docs/DESIGN_DECISIONS.md.
SPARSE_EMBEDDING_MODEL=

# --- Ticketing ---
# Still undecided (see docs/DESIGN_DECISIONS.md). "mock" is the default
# and needs NO credentials at all - you do not need to create any real
# keys until you've picked exactly one tool and reached that build step.
TICKETING_PROVIDER=mock        # mock | jira | asana | notion | linear | github_issues
TICKETING_API_KEY=
TICKETING_BASE_URL=
TICKETING_PROJECT_KEY=

# Tool-specific fields - uncomment only the block for whichever ONE
# ticketing tool you end up integrating (the rubric only needs one,
# not all three).

# Jira:
#   TICKETING_BASE_URL = https://<your-site>.atlassian.net
#   TICKETING_API_KEY  = an API token from
#                         https://id.atlassian.com/manage-profile/security/api-tokens
#   JIRA_EMAIL=                  # the Atlassian account email tied to the token
#   TICKETING_PROJECT_KEY=       # e.g. "SD"

# Asana:
#   TICKETING_API_KEY = a Personal Access Token from
#                        Asana -> My Settings -> Apps -> Manage Developer Apps
#   ASANA_WORKSPACE_GID=
#   ASANA_PROJECT_GID=

# Notion:
#   TICKETING_API_KEY = an internal integration secret from
#                        https://www.notion.so/my-integrations
#   NOTION_DATABASE_ID=          # you must also explicitly "Share" that
#                                  database with the integration in Notion's
#                                  UI, or API calls will 404.

# --- Retrieval / escalation tuning ---
RETRIEVAL_TOP_K=4
CONFIDENCE_THRESHOLD=0.0       # TODO: tune once you pick an escalation strategy

# --- Knowledge base paths ---
KNOWLEDGE_BASE_DIR=./data/knowledge_base
