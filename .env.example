# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Orchestration framework ---
# Chosen: LangGraph (see docs/DESIGN_DECISIONS.md). No separate API key needed.
ORCHESTRATION_FRAMEWORK=langgraph

# --- LLM provider (pick one) ---
LLM_PROVIDER=openai            # openai | anthropic | gemini | groq | ollama
LLM_API_KEY=
LLM_MODEL=                     # e.g. gpt-4o-mini, claude-haiku-4-5-20251001

# --- Vector store backend ---
# Chosen: Qdrant (see docs/DESIGN_DECISIONS.md) - for native sparse+dense hybrid search.
VECTOR_STORE_BACKEND=qdrant
# Local dev: run `docker run -p 6333:6333 qdrant/qdrant` (no API key needed).
# For Qdrant Cloud, set QDRANT_URL to your cluster URL and fill QDRANT_API_KEY.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=smartdesk_kb
# Alternative: qdrant-client embedded local mode (no Docker needed):
#   QdrantClient(path="./data/processed/qdrant_local") in vector_store.py
VECTOR_INDEX_DIR=./data/processed/vector_index

# --- Embeddings ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=
# For the sparse half of hybrid search (fastembed bundled BM25/SPLADE/miniCOIL):
SPARSE_EMBEDDING_MODEL=

# --- Ticketing ---
# Default: mock (no credentials needed). Only create real keys when you've
# picked ONE tool and reached that build step.
TICKETING_PROVIDER=mock        # mock | jira | asana | notion | linear | github_issues
TICKETING_API_KEY=
TICKETING_BASE_URL=
TICKETING_PROJECT_KEY=

# ── Jira (set TICKETING_PROVIDER=jira to activate) ──────────────────────────
# Step 1: Free account → https://www.atlassian.com/try/cloud/signup
# Step 2: Create a project, note the project KEY (e.g. "SD")
# Step 3: API token → https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=                    # your Atlassian account email
# TICKETING_BASE_URL=https://<your-site>.atlassian.net
# TICKETING_API_KEY=<api-token>
# TICKETING_PROJECT_KEY=SD

# Asana:  TICKETING_API_KEY=<PAT from Asana -> My Settings -> Apps>
#         ASANA_WORKSPACE_GID=
#         ASANA_PROJECT_GID=

# Notion: TICKETING_API_KEY=<secret from notion.so/my-integrations>
#         NOTION_DATABASE_ID=   (must also "Share" the DB with the integration in Notion UI)

# --- Retrieval / escalation tuning ---
RETRIEVAL_TOP_K=4
CONFIDENCE_THRESHOLD=0.4       # Escalate when top chunk score < this value.
                               # 0.0 = escalate only on zero results (too permissive — avoid)
                               # 0.4 = good default; agent answers confident hits, escalates weak ones
                               # 0.6 = stricter; agent escalates more borderline queries
HITL_MODE=cli                  # cli (stdin prompt) | ui (Gradio handles confirmation)

# --- Knowledge base paths ---
KNOWLEDGE_BASE_DIR=./data/knowledge_base
